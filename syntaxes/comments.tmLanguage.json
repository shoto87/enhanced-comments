{
  "scopeName": "source.custom-comments",
  "injectionSelector": "L:source -comment",
  "patterns": [
    { "begin": "^(\\s*)//%", "end": "$", "name": "comment.enhancer.bug" },
    { "begin": "^(\\s*)//!", "end": "$", "name": "comment.enhancer.error" },
    { "begin": "^(\\s*)//\\+", "end": "$", "name": "comment.enhancer.improve" },
    {
      "begin": "^(\\s*)//\\?",
      "end": "$",
      "name": "comment.enhancer.question"
    },
    {
      "begin": "^(\\s*)//\\*",
      "end": "$",
      "name": "comment.enhancer.highlight"
    },
    { "begin": "^(\\s*)//~", "end": "$", "name": "comment.enhancer.deprecated" }
  ]
}
