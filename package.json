{
  "name": "markit",
  "publisher": "pratikkodape",
  "displayName": "markit",
  "description": "Highlight comments and make them more meaningful, more understandable",
  "version": "0.2.1",
  "icon": "images/logo.png",
  "engines": {
    "vscode": "^1.102.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:python",
    "onLanguage:java"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "enhanced-comments.helloWorld",
        "title": "Hello World"
      }
    ],
    "grammars": [
      {
        "scopeName": "source.custom-comments",
        "path": "./syntaxes/comments.tmLanguage.json",
        "injectTo": [
          "source.js",
          "source.ts",
          "source.jsx",
          "source.tsx",
          "source.cpp",
          "source.c",
          "source.cs",
          "source.java",
          "source.go",
          "source.php",
          "source.python",
          "source.ruby"
        ]
      }
    ],
    "tokenColors": [
      {
        "scope": "comment.enhancer.bug",
        "settings": {
          "foreground": "#FFD700"
        }
      },
      {
        "scope": "comment.enhancer.error",
        "settings": {
          "foreground": "#FF4C4C"
        }
      },
      {
        "scope": "comment.enhancer.improve",
        "settings": {
          "foreground": "#4DA6FF"
        }
      },
      {
        "scope": "comment.enhancer.question",
        "settings": {
          "foreground": "#B266FF"
        }
      },
      {
        "scope": "comment.enhancer.highlight",
        "settings": {
          "foreground": "#33CC33"
        }
      },
      {
        "scope": "comment.enhancer.deprecated",
        "settings": {
          "foreground": "#888888",
          "fontStyle": "italic"
        }
      }
    ],
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "comment.enhancer.bug",
            "settings": {
              "foreground": "#FF5555"
            }
          },
          {
            "scope": "comment.enhancer.error",
            "settings": {
              "foreground": "#FF8800"
            }
          },
          {
            "scope": "comment.enhancer.improve",
            "settings": {
              "foreground": "#00C7A9"
            }
          },
          {
            "scope": "comment.enhancer.question",
            "settings": {
              "foreground": "#5CC8FF"
            }
          },
          {
            "scope": "comment.enhancer.highlight",
            "settings": {
              "foreground": "#7aff6e"
            }
          },
          {
            "scope": "comment.enhancer.deprecated",
            "settings": {
              "foreground": "#A0A0A0",
              "fontStyle": "italic"
            }
          }
        ]
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.102.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shoto87/enhanced-comments.git"
  }
}
