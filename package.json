{
  "name": "markit",
  "publisher": "pratikkodape",
  "displayName": "markit",
  "description": "to highlight comments and make it more meaningful , more understandable",
  "version": "0.1.3",
  "icon": "images/logo.png",
  "engines": {
    "vscode": "^1.102.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "enhanced-comments.helloWorld",
        "title": "Hello World"
      }
    ],
    "grammars": [
      {
        "scopeName": "source.custom-comments",
        "path": "./syntaxes/comments.tmLanguage.json",
        "injectTo": [
          "source.js",
          "source.ts",
          "source.jsx",
          "source.tsx",
          "source.cpp",
          "source.c",
          "source.cs",
          "source.java",
          "source.go",
          "source.php",
          "source.python",
          "source.ruby"
        ]
      }
    ],
    "semanticTokenColors": {
      "rules": {
        "comment.enhancer.bug": {
          "foreground": "#FFD700"
        },
        "comment.enhancer.error": {
          "foreground": "#FF4C4C"
        },
        "comment.enhancer.improve": {
          "foreground": "#4DA6FF"
        },
        "comment.enhancer.question": {
          "foreground": "#B266FF"
        },
        "comment.enhancer.highlight": {
          "foreground": "#33CC33"
        },
        "comment.enhancer.deprecated": {
          "foreground": "#888888",
          "fontStyle": "italic"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.102.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shoto87/enhanced-comments.git"
  }
}
